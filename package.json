{
  "name": "itsdad-llc",
  "version": "1.0.0",
  "description": "Its Dad LLC — Affiliate Marketing Platform",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "npm run build:client && npm run build:server",
    "build:client": "cd client && npm install && npx vite build",
    "build:server": "npx tsc -p tsconfig.server.json --noEmitOnError false || true",
    "start": "node dist/server/server.js",
    "dev": "concurrently \"npx ts-node-dev --respawn server/server.ts\" \"cd client && npx vite\""
  },
  "dependencies": {
    "body-parser": "^1.20.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.36.4",
    "express": "^4.21.2",
    "mysql2": "^3.11.5",
    "openai": "^6.32.0",
    "stripe": "^17.5.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.5",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.7",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.1.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
