# ─── Its Dad LLC — Environment Variables ─────────────────────────────────────
# Copy this file to .env for local development.
# Set these as environment variables in Railway for production.

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
VITE_APP_URL=https://www.itsdad.io

# ─── Database (MySQL / PlanetScale) ───────────────────────────────────────────
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE?ssl={"rejectUnauthorized":true}
DATABASE_URL=mysql://USER:PASSWORD@HOST:3306/itsdad

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create these in your Stripe dashboard:
#   Product: "Boss Membership" → Price: $9.99/mo recurring → copy Price ID here
#   Product: "Chief Membership" → Price: $19.99/mo recurring → copy Price ID here
#   Product: "Kingpin Membership" → Price: $24.99/mo recurring → copy Price ID here
STRIPE_PRICE_BOSS=price_...
STRIPE_PRICE_CHIEF=price_...
STRIPE_PRICE_KINGPIN=price_...

# ─── Cron Security ────────────────────────────────────────────────────────────
# Generate a random secret: openssl rand -hex 32
CRON_SECRET=your_random_secret_here

# ─── Email (MailerLite) ───────────────────────────────────────────────────────
MAILERLITE_API_KEY=your_mailerlite_api_key
